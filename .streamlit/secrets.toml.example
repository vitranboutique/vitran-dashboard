# ─────────────────────────────────────────────────────────────────────
# MẪU cấu hình. Đổi tên thành  secrets.toml  rồi điền (KHÔNG commit file thật).
# Trên Streamlit Cloud: dán nội dung này vào phần "Secrets".
# ─────────────────────────────────────────────────────────────────────

# ===== 1) Nguồn dữ liệu Sapo (chọn 1 cách) =====

# Cách A — Sapo Open API (khuyên dùng, chạy cloud được):
#   Tạo Private App trong Sapo → lấy key/secret (xem README).
SAPO_API_KEY    = "api_key_cua_ban"
SAPO_API_SECRET = "api_secret_cua_ban"

# Cách B — Cookie phiên (chỉ chạy local, hay hết hạn):
# SAPO_COOKIE = "dan_chuoi_cookie_o_day"


# ===== 2) Tài khoản đăng nhập dashboard =====
[auth.cookie]
name = "vitran_dashboard_auth"
key = "DOI_THANH_CHUOI_NGAU_NHIEN"   # tạo bằng: python -c "import secrets;print(secrets.token_hex(32))"
expiry_days = 30

# Mỗi nhân viên = một khối [auth.users.<tên_đăng_nhập>]
# role = "admin" hoặc "viewer". Mật khẩu để plaintext, app tự mã hóa khi chạy.
[auth.users.admin]
name = "Quản trị VITRAN"
password = "doi_mat_khau_nay"
role = "admin"

[auth.users.nv01]
name = "Nhân viên 01"
password = "mat_khau_nv01"
role = "viewer"
